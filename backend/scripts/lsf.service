[Unit]
Description=LSF Manager API Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/srv/prod/lsf/lsf-api
ExecStart=/srv/prod/lsf/lsf-api/scripts/start.sh
ExecStop=/bin/kill -s SIGTERM $MAINPID
Restart=on-failure
TimeoutStopSec=60
KillMode=process

[Install]
WantedBy=multi-user.target
